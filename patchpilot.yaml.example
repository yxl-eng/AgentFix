openai:
  model: deepseek-v3-2-251201
  api_key_env_var: ARK_API_KEY
  base_url: https://ark.cn-beijing.volces.com/api/v3
  transport: rest_chat_completions
  analysis_reasoning_effort: medium
  patch_reasoning_effort: high

github:
  token_env_var: GITHUB_TOKEN
  api_base_url: https://api.github.com

guardrails:
  max_changed_files: 6
  max_patch_lines: 600
  min_confidence: 0.45
  ignored_paths:
    - .git
    - .venv
    - .pytest_cache
    - __pycache__
    - node_modules

validation:
  python_executable: python
  test_commands: []
  service_start_timeout_seconds: 20
  healthcheck_timeout_seconds: 20
  healthcheck_interval_seconds: 1

runtime:
  artifact_root: .patchpilot-artifacts
  max_repair_attempts: 3

server:
  host: 0.0.0.0
  port: 8080
  poll_interval_seconds: 10
  state_path: .patchpilot-state/events.sqlite3

agent:
  planner:
    enabled: true
    max_steps: 8
    allowed_tools:
      - Read Log
      - Inspect Config
      - Check Runtime
      - Search Similar Fixes
      - Read Code
      - Generate Regression Test
      - Run Test
      - Git Commit
      - Record Repair
      - Notify Feishu
  risk:
    max_changed_files: 6
    max_changed_lines: 600
  report:
    notify_on_ignored: false
    notify_on_report_only: true
    notify_on_needs_more_context: true

targets:
  # my-service:

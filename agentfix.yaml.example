openai:
  model: deepseek-v3-2-251201
  api_key_env_var: ARK_API_KEY
  base_url: https://ark.cn-beijing.volces.com/api/v3
  transport: rest_chat_completions
  analysis_reasoning_effort: medium
  patch_reasoning_effort: high

github:
  token_env_var: GITHUB_TOKEN
  api_base_url: https://api.github.com

guardrails:
  max_changed_files: 3
  max_patch_lines: 250
  min_confidence: 0.45
  ignored_paths:
    - .git
    - .venv
    - .pytest_cache
    - __pycache__
    - node_modules

validation:
  python_executable: python
  test_commands: []
  service_start_timeout_seconds: 20
  healthcheck_timeout_seconds: 20
  healthcheck_interval_seconds: 1

runtime:
  artifact_root: .agentfix-artifacts
  max_repair_attempts: 2

server:
  host: 0.0.0.0
  port: 8080
  poll_interval_seconds: 10
  state_path: .agentfix-state/events.sqlite3

targets:
  # my-service:
  #   repo_full_name: owner/my-service
  #   repo_path: C:/path/to/my-service
  #   base_branch: main
  #   service_log_file: logs/app.log
  #   start_command: npm run dev
  #   healthcheck_url: http://localhost:3000/health
  #   test_commands:
  #     - npm test
  #   verification_requests:
  #     - method: GET
  #       url: http://localhost:3000/api/users/1
  #       expected_status: 200

feishu:
  webhook_url_env_var: FEISHU_WEBHOOK_URL
  webhook_secret_env_var: FEISHU_WEBHOOK_SECRET

records:
  root: records
  auto_commit: true
